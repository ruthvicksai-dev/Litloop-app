{
  "expo": {
    "name": "LitLoop",
    "slug": "litloop",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "litloop",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ruthvicksai.litloop",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Litloop needs your location to provide accurate book delivery to your doorstep.",
        "NSCameraUsageDescription": "Litloop needs camera access to scan book ISBN barcodes."
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#1C1917",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.ruthvicksai.litloop",
      "versionCode": 3,
      "permissions": [
        "POST_NOTIFICATIONS",
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "$EXPO_PUBLIC_GOOGLE_MAPS_KEY"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/transparent.png",
          "resizeMode": "contain",
          "backgroundColor": "#0F2027"
        }
      ],
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "Litloop needs camera access to scan book ISBN barcodes."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-location",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4d7bfaa0-7d9b-4cc3-9c1d-7be6b5a6fc6d"
      }
    }
  }
}
